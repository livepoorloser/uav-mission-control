<!-- 功能：启动任务控制器调试流程，可选择不同检测节点。 -->

<launch>
  <arg name="use_rknn_detector" default="true" />
  <!-- detector_type: rknn | opencv | color | legacy -->
  <arg name="detector_type" default="rknn" />
  <arg name="drone_ns" default="Drone_2" />
  <arg name="rknn_model_path" default="/home/orangepi/catkin_ws/src/animal_yolov5/rknnModel/best_i8.rknn" />
  <arg name="opencv_model_path" default="/home/orangepi/catkin_ws/src/drone_code/yolov5-master/runs/train/exp13/weights/best.onnx" />
  <arg name="color_label" default="tiger" />
  <arg name="color_h_min" default="170" />
  <arg name="color_h_max" default="10" />
  <arg name="color_s_min" default="80" />
  <arg name="color_s_max" default="255" />
  <arg name="color_v_min" default="80" />
  <arg name="color_v_max" default="255" />
  <arg name="color_verbose_log" default="true" />
  <arg name="color_log_period" default="0.5" />
  <rosparam command="load" file="$(find drone_code)/config/mission_controller.yaml" />

  <node pkg="drone_code" name="path_planning" type="path_planning_node" output="screen" />

  <group ns="$(arg drone_ns)">
    <node pkg="drone_code" name="mission_controller" type="mission_controller_node" output="screen">
      <rosparam file="$(find drone_code)/config/mission_controller.yaml" command="load" />
    </node>

    <node if="$(eval arg('detector_type') == 'rknn' and arg('use_rknn_detector') == 'true')" pkg="drone_code" type="animal_detector_rknn.py" name="animal_detector" output="screen">
      <param name="model_type" value="rknn" />
      <param name="model_path" value="$(arg rknn_model_path)" />
      <rosparam param="classes">[tiger, peacock, monkey, elephant, wolf]</rosparam>
      <param name="camera_id" value="0" />
      <param name="frame_width" value="640" />
      <param name="frame_height" value="480" />
      <param name="loop_hz" value="15.0" />
      <param name="npu_core" value="-1" />
      <param name="region_width_ratio" value="0.3" />
      <param name="region_height_ratio" value="0.2" />
      <param name="min_area" value="500" />
      <param name="max_area" value="25000" />
      <param name="pause_base_seconds" value="2.0" />
      <param name="pause_per_object_seconds" value="1.0" />
      <param name="show_window" value="false" />
      <param name="publish_raw_image" value="true" />
      <param name="raw_image_topic" value="vision/raw_image" />
      <param name="raw_frame_id" value="animal_detector_camera" />
      <param name="publish_debug_image" value="true" />
      <param name="debug_image_topic" value="vision/detection_image" />
      <param name="debug_frame_id" value="animal_detector_camera" />
      <param name="enabled_by_default" value="true" />
      <param name="control_enabled" value="false" />
      <param name="control_scale" value="0.001" />
      <param name="control_hold_seconds" value="1.0" />
      <param name="obj_thresh" value="0.55" />
      <param name="nms_thresh" value="0.25" />
      <param name="score_thresh" value="0.50" />
      <param name="outputs_already_sigmoid" value="true" />
      <param name="pose_topic" value="mavros/local_position/pose" />
    </node>

    <node if="$(eval arg('detector_type') == 'opencv')" pkg="drone_code" type="animal_detector_node" name="animal_detector" output="screen">
      <param name="model_path" value="$(arg opencv_model_path)" />
      <rosparam param="classes">[tiger, peacock, monkey, elephant, wolf]</rosparam>
      <param name="camera_id" value="0" />
      <param name="img_size" value="640" />
      <param name="obj_thresh" value="0.55" />
      <param name="nms_thresh" value="0.25" />
      <param name="frame_width" value="640" />
      <param name="frame_height" value="480" />
      <param name="min_area" value="500.0" />
      <param name="max_area" value="25000.0" />
      <param name="region_width_ratio" value="0.3" />
      <param name="region_height_ratio" value="0.2" />
      <param name="pause_base_seconds" value="2.0" />
      <param name="pause_per_object_seconds" value="1.0" />
      <param name="show_window" value="false" />
      <param name="publish_debug_image" value="true" />
      <param name="debug_image_topic" value="vision/detection_image" />
      <param name="debug_frame_id" value="animal_detector_camera" />
      <param name="enabled_by_default" value="true" />
      <param name="control_enabled" value="false" />
      <param name="control_scale" value="0.001" />
      <param name="control_hold_seconds" value="1.0" />
      <param name="pose_topic" value="mavros/local_position/pose" />
    </node>

    <node if="$(eval arg('detector_type') == 'color')" pkg="drone_code" type="color_block_detector.py" name="animal_detector" output="screen">
      <param name="label" value="$(arg color_label)" />
      <param name="h_min" value="$(arg color_h_min)" />
      <param name="h_max" value="$(arg color_h_max)" />
      <param name="s_min" value="$(arg color_s_min)" />
      <param name="s_max" value="$(arg color_s_max)" />
      <param name="v_min" value="$(arg color_v_min)" />
      <param name="v_max" value="$(arg color_v_max)" />
      <param name="verbose_log" value="$(arg color_verbose_log)" />
      <param name="log_period" value="$(arg color_log_period)" />
    </node>

    <node if="$(eval arg('detector_type') == 'legacy' or (arg('detector_type') == 'rknn' and arg('use_rknn_detector') == 'false'))" pkg="drone_code" type="animal_detector_node" name="animal_detector" output="screen">
      <param name="model_path" value="$(arg opencv_model_path)" />
      <rosparam param="classes">[tiger, peacock, monkey, elephant, wolf]</rosparam>
      <param name="camera_id" value="0" />
      <param name="img_size" value="640" />
      <param name="obj_thresh" value="0.55" />
      <param name="nms_thresh" value="0.25" />
      <param name="frame_width" value="640" />
      <param name="frame_height" value="480" />
      <param name="min_area" value="500.0" />
      <param name="max_area" value="25000.0" />
      <param name="region_width_ratio" value="0.3" />
      <param name="region_height_ratio" value="0.2" />
      <param name="pause_base_seconds" value="2.0" />
      <param name="pause_per_object_seconds" value="1.0" />
      <param name="show_window" value="false" />
      <param name="publish_debug_image" value="true" />
      <param name="debug_image_topic" value="vision/detection_image" />
      <param name="debug_frame_id" value="animal_detector_camera" />
      <param name="enabled_by_default" value="true" />
      <param name="control_enabled" value="false" />
      <param name="control_scale" value="0.001" />
      <param name="control_hold_seconds" value="1.0" />
      <param name="pose_topic" value="mavros/local_position/pose" />
    </node>
  </group>
</launch>
